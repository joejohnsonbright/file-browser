{
  "standard": "WCAG2AA",
  "includeNotices": false,
  "includeWarnings": true,
  "ignore": ["notice", "warning"],
  "chromeLaunchConfig": {
    "args": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-gpu"
    ]
  },
  "timeout": 30000,
  "wait": 1000
}
